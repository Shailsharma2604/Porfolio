# GitHub live dashboard (required for commits, activity & repos)
# Create a token at https://github.com/settings/tokens — no scopes needed for public data
GITHUB_USERNAME=Shailsharma2604
GITHUB_TOKEN=

# Optional: cache GitHub responses (milliseconds, default 300000 = 5 min)
# GITHUB_CACHE_MS=300000

# Server port for local dev (default 3000)
# PORT=3000

# LinkedIn profile photo (optional override — default: config/social.json → linkedin.vanity)
# Use the slug from linkedin.com/in/<vanity> or paste the full profile URL
# LINKEDIN_VANITY=shail2604

# Photo cache TTL in ms (default 86400000 = 24h). Server re-fetches after this interval.
# LINKEDIN_PHOTO_CACHE_MS=86400000

# LinkedIn profile headline (optional — default: config/social.json → linkedin.headline)
# Server tries Open Graph on your public profile, then falls back to social.json.
# Update social.json when you change your headline if automated fetch is blocked (HTTP 999).
# LINKEDIN_PROFILE_CACHE_MS=3600000

# Contact form email (Resend — https://resend.com)
# Without RESEND_API_KEY, submissions are logged only and the form falls back to mailto:.
# Sandbox: onboarding@resend.dev only delivers to your verified Resend account email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=shail020604@gmail.com
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Production: verify a domain in Resend, then use e.g. Portfolio <contact@yourdomain.com>
